<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.turecomendador"
       name="Mi Recomendador Personal — Repo"
       version="1.0.0"
       provider-name="iolalo">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.addon.repository" name="Mi Recomendador Personal">
    <info compressed="false">https://iolalo.github.io/kodi-repo/addons.xml</info>
    <checksum>https://iolalo.github.io/kodi-repo/addons.xml.md5</checksum>
    <datadir zip="true">https://iolalo.github.io/kodi-repo/</datadir>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary lang="es_ES">Repositorio del Recomendador Personal</summary>
    <description lang="es_ES">Repositorio privado con el addon Mi Recomendador Personal.</description>
    <platform>all</platform>
  </extension>

</addon>
