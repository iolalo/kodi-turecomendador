<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="plugin.video.turecomendador" name="Mi Recomendador Personal" version="0.6.0" provider-name="iolalo">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
      <import addon="script.module.requests" version="2.27.0" />
      <import addon="plugin.video.elementum" version="0.1.0" optional="true" />
      <import addon="service.subtitles.opensubtitles" optional="true" />
      <import addon="service.subtitles.subdivx" optional="true" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="es_ES">Recomendador de películas personalizado</summary>
      <description lang="es_ES">
      Recomendaciones basadas en tu historial de Trakt y tu perfil de
      cine independiente estilo MUBI: slow cinema, cine europeo e
      internacional, historias íntimas y contemplativas.
    </description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="repository.turecomendador" name="Mi Recomendador Personal — Repo" version="1.0.2" provider-name="iolalo">
    <extension point="xbmc.addon.repository" name="Mi Recomendador Personal">
      <dir minversion="21.0.0">
        <info compressed="false">https://iolalo.github.io/kodi-turecomendador/addons.xml</info>
        <checksum algo="md5">https://iolalo.github.io/kodi-turecomendador/addons.xml.md5</checksum>
        <datadir zip="true">https://iolalo.github.io/kodi-turecomendador/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="es_ES">Repositorio del Recomendador Personal</summary>
      <description lang="es_ES">Repositorio privado con el addon Mi Recomendador Personal.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="script.turecomendador.wizard" name="Mi Recomendador — Instalador" version="1.0.0" provider-name="iolalo">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.script" library="default.py" />
    <extension point="xbmc.addon.metadata">
      <summary lang="es_ES">Instala la build completa de Mi Recomendador</summary>
      <description lang="es_ES">Descarga e instala la configuración completa de Kodi: skin Arctic Zephyr Mod, addons, fuentes y ajustes. Igual que una build de comunidad.</description>
      <platform>all</platform>
    </extension>
  </addon>
</addons>